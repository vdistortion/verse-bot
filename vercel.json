{
  "public": true,
  "functions": {
    "api/webhook.ts": {
      "maxDuration": 10
    }
  },
  "routes": [
    {
      "src": "/content-images/(.*)",
      "dest": "/content-images/$1"
    },
    {
      "src": "/api/webhook",
      "dest": "/api/webhook.ts"
    },
    {
      "handle": "filesystem"
    }
  ]
}
