{
  "name": "verse-bot-monorepo",
  "description": "Universal bot framework – write commands once, run on Telegram and VK",
  "private": true,
  "scripts": {
    "docker:dev:up": "docker compose -f apps/imp-bot/docker-compose.yml up -d",
    "docker:dev:down": "docker compose -f apps/imp-bot/docker-compose.yml down",
    "docker:dev:clean": "docker compose -f apps/imp-bot/docker-compose.yml down -v --rmi all",
    "prepare": "cp -n .env.example .env",
    "build": "tsc --build",
    "build:miniapp": "npm run build --workspace=@verse-bot/miniapp",
    "build:release": "tsc --build tsconfig.build.json",
    "dev": "dotenv -- env tsx watch --watch=packages --conditions=source apps/imp-bot/src/index.ts",
    "clean": "./tools/clean.sh",
    "clean:all": "./tools/clean-all.sh",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "format": "prettier . --write"
  },
  "prettier": {
    "singleQuote": true,
    "printWidth": 100
  },
  "author": "Valentin <valentin.distortion@gmail.com> (https://github.com/vdistortion)",
  "homepage": "https://github.com/vdistortion/verse-bot",
  "license": "Apache-2.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "devDependencies": {
    "@types/debug": "^4.1.13",
    "@types/node": "^25.9.1",
    "debug": "^4.4.3",
    "dotenv-cli": "^11.0.0",
    "prettier": "3.8.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitepress": "^1.6.4"
  }
}
