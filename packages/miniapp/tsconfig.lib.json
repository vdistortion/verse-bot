{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "lib": ["ES2022", "DOM"],
    "declaration": true,
    "declarationMap": true,
    "inlineSources": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "rootDir": ".",
    "paths": {
      "@verse-bot/miniapp": ["./src/public-api.ts"]
    }
  },
  "angularCompilerOptions": {
    "compilationMode": "partial"
  },
  "include": ["src/**/*.ts", "angular/**/*.ts"]
}
