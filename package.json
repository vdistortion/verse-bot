{
  "name": "universal-vercel-bot",
  "version": "1.0.0",
  "description": "Monorepo for Telegram and VK bots, and Angular MiniApp",
  "private": true,
  "scripts": {
    "prepare": "cp -n .env.example .env",
    "build": "tsc --build",
    "dev": "dotenv -- env tsx apps/bot/src/index.ts",
    "dev:tg": "dotenv -- env VK_TOKEN='' VK_GROUP_ID='' tsx apps/bot/src/index.ts",
    "dev:vk": "dotenv -- env TELEGRAM_BOT_TOKEN='' tsx apps/bot/src/index.ts",
    "clean": "rm -rf dist && find . -name \"*.tsbuildinfo\" -delete",
    "clean:all": "npm run clean && rm -rf node_modules package-lock.json && npm i",
    "format": "prettier . --write"
  },
  "prettier": {
    "singleQuote": true,
    "printWidth": 100
  },
  "author": "Valentin <valentin.distortion@gmail.com> (https://github.com/vdistortion)",
  "homepage": "https://github.com/vdistortion/universal-vercel-bot",
  "license": "Apache-2.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "keywords": [
    "telegram-bot",
    "vk-bot",
    "monorepo",
    "typescript",
    "boilerplate",
    "grammy",
    "vercel",
    "supabase"
  ],
  "devDependencies": {
    "@types/debug": "^4.1.13",
    "@types/node": "^25.6.0",
    "debug": "^4.4.3",
    "dotenv-cli": "^11.0.0",
    "prettier": "3.5.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
